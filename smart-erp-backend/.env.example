# ====================================================
# SmartERP Backend Environment Configuration Template
# ====================================================

# Server Port
SERVER_PORT=9521

# Spring Profiles Active (Keep 'local' for dev or omit)
# SPRING_PROFILES_ACTIVE=local

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/smarterp
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# JPA Configuration
JPA_SHOW_SQL=true
SQL_INIT_MODE=always

# JWT Configuration
JWT_SECRET=dGhpcy1pcy1hLXNlY3JldC1rZXktZm9yLXNtYXJ0LWVycC1hcHBsaWNhdGlvbi1kZXZlbG9wbWVudA==
JWT_EXPIRATION=86400000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_SSL=false

# Google OAuth Configuration (Optional/Unused in dev)
# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret

# Upload & File Limits
MAX_UPLOAD_SIZE=20MB
LOG_LEVEL=INFO
