# ====================================================
# SmartERP Frontend Environment Configuration Template
# ====================================================

# Base API URL matching the backend server endpoint
VITE_API_BASE_URL=http://localhost:9521/api/v1

# General App Brand Config
VITE_PORT=3021
VITE_APP_NAME=SmartERP
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# Diagnostic Logs Control
VITE_ENABLE_DEBUG=false

# Google OAuth Integration details
VITE_GOOGLE_CLIENT_ID=

# Keyboard Scoped Preferences
VITE_ENABLE_KEYBOARD_MODE=false
VITE_ENABLE_COMMAND_PALETTE=true
